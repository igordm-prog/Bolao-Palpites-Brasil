<%- include("../partials/head", { title }) %>
<section class="workspace">
  <aside class="sidebar">
    <h2>Painel</h2>
    <a href="/admin">Painel</a>
    <a href="/admin/boloes">Boloes</a>
    <a href="/admin/jogos">Jogos</a>
    <a href="/admin/resultados">Resultados</a>
  </aside>
  <div class="content">
    <h1>Jogos</h1>
    <form class="panel form" action="/admin/jogos" method="post">
      <h2>Novo jogo</h2>
      <div class="form-grid">
        <label>Bolao
          <select name="poolId" required>
            <% if (!pools.length) { %><option value="">Crie um bolao primeiro</option><% } %>
            <% pools.forEach((pool) => { %><option value="<%= pool.id %>"><%= pool.name %></option><% }) %>
          </select>
        </label>
        <label>Campeonato
          <select name="championship">
            <% championships.forEach((item) => { %><option value="<%= item %>"><%= item %></option><% }) %>
          </select>
        </label>
        <label>Rodada <input name="round"></label>
        <label class="team-select-field">Mandante
          <span class="team-select-control">
            <img class="team-select-crest" data-team-preview="homeTeam" alt="" hidden>
            <select name="homeTeam" required>
              <option value="">Selecione o mandante</option>
              <% teams.forEach((team) => { %>
                <option value="<%= team.name %>" data-championship="<%= team.championship %>" data-crest="<%= teamCrestUrl(team.name) %>"><%= team.name %></option>
              <% }) %>
            </select>
          </span>
        </label>
        <label class="team-select-field">Visitante
          <span class="team-select-control">
            <img class="team-select-crest" data-team-preview="awayTeam" alt="" hidden>
            <select name="awayTeam" required>
              <option value="">Selecione o visitante</option>
              <% teams.forEach((team) => { %>
                <option value="<%= team.name %>" data-championship="<%= team.championship %>" data-crest="<%= teamCrestUrl(team.name) %>"><%= team.name %></option>
              <% }) %>
            </select>
          </span>
        </label>
        <label>Data <input type="date" name="matchDate" required></label>
        <label>Horario <input type="time" name="matchTime" required></label>
        <label>Local <input name="venue"></label>
      </div>
      <button class="button" type="submit" <%= !pools.length ? "disabled" : "" %>>Cadastrar jogo</button>
      <% if (!pools.length) { %>
        <p class="muted">Antes de cadastrar jogos, crie um bolao em Boloes.</p>
      <% } %>
    </form>
    <div class="table-panel">
      <table>
        <thead><tr><th>Bolao</th><th>Campeonato</th><th>Jogo</th><th>Data</th><th>Status</th><th>Acoes</th></tr></thead>
        <tbody>
          <% if (!matches.length) { %>
            <tr><td colspan="6">Nenhum jogo cadastrado.</td></tr>
          <% } %>
          <% matches.forEach((match) => { %>
            <% const homeCrest = teamCrestUrl(match.homeTeam); const awayCrest = teamCrestUrl(match.awayTeam); %>
            <tr>
              <td><%= match.poolName %></td>
              <td><%= match.championship %></td>
              <td>
                <span class="admin-match-teams">
                  <strong><%= match.homeTeam %></strong>
                  <% if (homeCrest) { %>
                    <img class="crest-img" src="<%= homeCrest %>" alt="">
                  <% } else { %>
                    <span class="crest-missing">Pendente</span>
                  <% } %>
                  <span>x</span>
                  <% if (awayCrest) { %>
                    <img class="crest-img" src="<%= awayCrest %>" alt="">
                  <% } else { %>
                    <span class="crest-missing">Pendente</span>
                  <% } %>
                  <strong><%= match.awayTeam %></strong>
                </span>
              </td>
              <td><%= match.matchDate %> <%= match.matchTime %></td>
              <td><span class="badge"><%= labelForStatus(match.status) %></span></td>
              <td>
                <form class="inline-form" action="/admin/jogos/<%= match.id %>/excluir" method="post" onsubmit="return confirm('Excluir este jogo? Os palpites desse jogo tambem serao removidos.');">
                  <button class="button danger small" type="submit">Excluir</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</section>
<script>
  (() => {
    const championship = document.querySelector('select[name="championship"]');
    const teamSelects = [...document.querySelectorAll('select[name="homeTeam"], select[name="awayTeam"]')];

    function updatePreview(select) {
      const option = select.selectedOptions[0];
      const preview = document.querySelector(`[data-team-preview="${select.name}"]`);
      if (!preview) return;
      if (!option?.dataset.crest) {
        preview.hidden = true;
        return;
      }
      preview.src = option.dataset.crest;
      preview.alt = `Brasao ${option.value}`;
      preview.hidden = false;
    }

    function filterTeams() {
      const selectedChampionship = championship?.value || "";
      teamSelects.forEach((select) => {
        [...select.options].forEach((option) => {
          if (!option.value) return;
          option.hidden = Boolean(selectedChampionship) && option.dataset.championship !== selectedChampionship;
        });
        const selected = select.selectedOptions[0];
        if (selected?.hidden) select.value = "";
        updatePreview(select);
      });
    }

    championship?.addEventListener("change", filterTeams);
    teamSelects.forEach((select) => select.addEventListener("change", () => updatePreview(select)));
    filterTeams();
  })();
</script>
<%- include("../partials/footer") %>
