<%- include("../partials/head", { title }) %>
<section class="workspace admin-workspace">
  <aside class="sidebar">
    <h2>Admin</h2>
    <a href="/admin">Painel</a>
    <a href="/admin/boloes">Boloes</a>
    <a href="/admin/jogos">Jogos</a>
    <a href="/admin/resultados">Resultados</a>
    <a class="active" href="/admin/sofascore-robo">Robo SofaScore</a>
    <a href="/admin/logs">Auditoria</a>
  </aside>

  <div class="content">
    <div class="section-header">
      <div>
        <p class="eyebrow">Monitor experimental</p>
        <h1>Robo SofaScore</h1>
        <p class="muted">Executa um navegador real no servidor, le os jogos do SofaScore e salva um cache para o sistema consultar.</p>
      </div>
    </div>

    <form class="panel form sofascore-probe-form" action="/admin/sofascore-robo/testar" method="post">
      <h2>Atualizar cache do monitor</h2>
      <label>URL do SofaScore
        <input type="url" name="url" value="<%= latestSnapshot?.sourceUrl || lastResult?.url || defaultUrl %>" required>
      </label>
      <p class="muted">Por enquanto o monitor roda pelo botao. Depois de validar estabilidade, vamos colocar intervalo automatico.</p>
      <button class="button" type="submit">Atualizar cache agora</button>
    </form>

    <% if (latestSnapshot) { %>
      <section class="panel sofascore-result <%= latestSnapshot.ok ? 'is-ok' : 'is-error' %>">
        <div class="account-section-head">
          <div>
            <p class="eyebrow">Cache atual</p>
            <h2><%= latestSnapshot.ok ? "Monitor atualizado" : "Monitor com erro" %></h2>
          </div>
          <span class="badge <%= latestSnapshot.ok ? 'paid' : 'canceled' %>"><%= latestSnapshot.ok ? "OK" : "Erro" %></span>
        </div>

        <div class="account-stats sofascore-result-stats">
          <article>
            <span>Finalizado em</span>
            <strong><%= formatDateTime(latestSnapshot.finishedAt) %></strong>
          </article>
          <article>
            <span>Texto lido</span>
            <strong><%= latestSnapshot.textLength || 0 %></strong>
            <small>caracteres visiveis</small>
          </article>
          <article>
            <span>Jogos em cache</span>
            <strong><%= latestSnapshot.gamesCount || latestSnapshot.games?.length || 0 %></strong>
          </article>
        </div>

        <% if (latestSnapshot.error) { %>
          <div class="flash error"><p><%= latestSnapshot.error %></p></div>
        <% } %>

        <div class="sofascore-result-grid">
          <article>
            <h3>Pagina capturada</h3>
            <p><strong>Titulo:</strong> <%= latestSnapshot.title || "-" %></p>
            <p><strong>URL:</strong> <%= latestSnapshot.currentUrl || latestSnapshot.sourceUrl %></p>
          </article>

          <article>
            <h3>Jogos salvos no cache</h3>
            <% if (latestSnapshot.games?.length) { %>
              <ul class="compact-list sofascore-game-cache-list">
                <% latestSnapshot.games.forEach((game) => { %>
                  <li>
                    <strong><%= game.homeTeam %> x <%= game.awayTeam %></strong>
                    <span class="muted"><%= game.competition || "SofaScore" %><%= game.group ? ` - ${game.group}` : "" %></span>
                    <span class="muted">Horario <%= game.time || "-" %> | Status <%= game.status || "-" %> | Minuto <%= game.minute || 0 %> | Placar <%= game.score || "-" %></span>
                    <span class="muted">Odds 1X2: 1 <%= game.odds1x2?.home || "-" %> | X <%= game.odds1x2?.draw || "-" %> | 2 <%= game.odds1x2?.away || "-" %></span>
                    <span class="muted">Stats base: <%= game.stats?.totalShots || 0 %> finalizacoes, <%= game.stats?.shotsOnTarget || 0 %> no alvo, <%= game.stats?.corners || 0 %> escanteios, <%= game.stats?.dangerousAttacks || 0 %> ataques perigosos</span>
                  </li>
                <% }) %>
              </ul>
            <% } else { %>
              <p class="muted">Nenhum jogo estruturado foi salvo. Confira as linhas brutas abaixo.</p>
            <% } %>
          </article>
        </div>

        <details class="sofascore-raw-lines">
          <summary>Ver linhas brutas capturadas</summary>
          <pre><%= (latestSnapshot.lines || []).slice(0, 120).join("\n") %></pre>
        </details>
      </section>
    <% } %>

    <section class="table-panel sofascore-history-panel">
      <h2>Ultimas leituras salvas</h2>
      <table>
        <thead>
          <tr>
            <th>Data</th>
            <th>Status</th>
            <th>Jogos</th>
            <th>URL</th>
            <th>Erro</th>
          </tr>
        </thead>
        <tbody>
          <% if (!snapshots.length) { %>
            <tr><td colspan="5">Nenhuma leitura salva ainda.</td></tr>
          <% } %>
          <% snapshots.forEach((snapshot) => { %>
            <tr>
              <td><%= formatDateTime(snapshot.finishedAt || snapshot.createdAt) %></td>
              <td><span class="badge <%= snapshot.ok ? 'paid' : 'canceled' %>"><%= snapshot.ok ? "OK" : "Erro" %></span></td>
              <td><strong><%= snapshot.gamesCount || snapshot.games?.length || 0 %></strong></td>
              <td><small><%= snapshot.currentUrl || snapshot.sourceUrl || "-" %></small></td>
              <td><small><%= snapshot.error || "-" %></small></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </section>
  </div>
</section>
<%- include("../partials/footer") %>
