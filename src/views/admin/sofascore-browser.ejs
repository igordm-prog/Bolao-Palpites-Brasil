<%- include("../partials/head", { title }) %>
<section class="workspace admin-workspace">
  <aside class="sidebar">
    <h2>Admin</h2>
    <a href="/admin">Painel</a>
    <a href="/admin/boloes">Boloes</a>
    <a href="/admin/jogos">Jogos</a>
    <a href="/admin/resultados">Resultados</a>
    <a class="active" href="/admin/sofascore-robo">Robo SofaScore</a>
    <a href="/admin/logs">Auditoria</a>
  </aside>

  <div class="content">
    <div class="section-header">
      <div>
        <p class="eyebrow">Teste experimental</p>
        <h1>Robo SofaScore</h1>
        <p class="muted">Executa um navegador real no servidor para tentar ler a tela do SofaScore. Use apenas para teste interno.</p>
      </div>
    </div>

    <form class="panel form sofascore-probe-form" action="/admin/sofascore-robo/testar" method="post">
      <h2>Executar leitura</h2>
      <label>URL do SofaScore
        <input type="url" name="url" value="<%= lastResult?.url || defaultUrl %>" required>
      </label>
      <p class="muted">O primeiro teste pode demorar porque o navegador precisa abrir, carregar scripts e esperar a pagina montar.</p>
      <button class="button" type="submit">Executar teste agora</button>
    </form>

    <% if (lastResult) { %>
      <section class="panel sofascore-result <%= lastResult.ok ? 'is-ok' : 'is-error' %>">
        <div class="account-section-head">
          <div>
            <p class="eyebrow">Ultimo teste</p>
            <h2><%= lastResult.ok ? "Leitura executada" : "Leitura falhou" %></h2>
          </div>
          <span class="badge <%= lastResult.ok ? 'paid' : 'canceled' %>"><%= lastResult.ok ? "OK" : "Erro" %></span>
        </div>

        <div class="account-stats sofascore-result-stats">
          <article>
            <span>Finalizado em</span>
            <strong><%= formatDateTime(lastResult.finishedAt) %></strong>
          </article>
          <article>
            <span>Texto lido</span>
            <strong><%= lastResult.textLength || 0 %></strong>
            <small>caracteres visiveis</small>
          </article>
          <article>
            <span>Jogos provaveis</span>
            <strong><%= lastResult.games?.length || 0 %></strong>
          </article>
        </div>

        <% if (lastResult.error) { %>
          <div class="flash error"><p><%= lastResult.error %></p></div>
        <% } %>

        <div class="sofascore-result-grid">
          <article>
            <h3>Pagina capturada</h3>
            <p><strong>Titulo:</strong> <%= lastResult.title || "-" %></p>
            <p><strong>URL:</strong> <%= lastResult.currentUrl || lastResult.url %></p>
          </article>

          <article>
            <h3>Jogos provaveis</h3>
            <% if (lastResult.games?.length) { %>
              <ul class="compact-list">
                <% lastResult.games.forEach((game) => { %>
                  <li><strong><%= game.homeTeam %> x <%= game.awayTeam %></strong> <span class="muted"><%= game.time %> <%= game.score || "" %></span></li>
                <% }) %>
              </ul>
            <% } else { %>
              <p class="muted">Nenhum jogo estruturado foi identificado. Confira as linhas brutas abaixo.</p>
            <% } %>
          </article>
        </div>

        <details class="sofascore-raw-lines">
          <summary>Ver linhas brutas capturadas</summary>
          <pre><%= (lastResult.lines || []).slice(0, 120).join("\n") %></pre>
        </details>
      </section>
    <% } %>
  </div>
</section>
<%- include("../partials/footer") %>
