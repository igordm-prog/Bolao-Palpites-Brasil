<%- include("../partials/head", { title }) %>
<section class="workspace admin-workspace">
  <aside class="sidebar">
    <h2>Admin</h2>
    <a href="/admin">Painel</a>
    <a href="/admin/boloes">Boloes</a>
    <a href="/admin/jogos">Jogos</a>
    <a href="/admin/resultados">Resultados</a>
    <a class="active" href="/admin/sofascore-robo">Robo SofaScore</a>
    <a href="/admin/logs">Auditoria</a>
  </aside>

  <div class="content">
    <div class="section-header">
      <div>
        <p class="eyebrow">Monitor experimental</p>
        <h1>Robo SofaScore</h1>
        <p class="muted">Executa um navegador real no servidor, le os jogos do SofaScore e salva um cache para o sistema consultar.</p>
      </div>
    </div>

    <form class="panel form sofascore-probe-form" action="/admin/sofascore-robo/testar" method="post">
      <h2>Atualizar cache do monitor</h2>
      <label>URL do SofaScore
        <input type="url" name="url" value="<%= latestSnapshot?.sourceUrl || lastResult?.url || defaultUrl %>" required>
      </label>
      <p class="muted">O monitor tambem roda automaticamente a cada 60 segundos. Use o botao apenas para forcar uma leitura agora.</p>
      <button class="button" type="submit">Atualizar cache agora</button>
    </form>

    <% if (latestSnapshot) { %>
      <%
        const allGames = latestSnapshot.games || [];
        const isLiveStatus = (game = {}) => {
          const status = String(game.status || "").trim();
          const statusLabel = String(game.statusLabel || "").trim();
          const joined = `${status} ${statusLabel}`;
          return ["Ao vivo", "Intervalo"].includes(statusLabel) ||
            /^\d{1,3}(\+\d{1,2})?'?$/.test(status) ||
            /^\d{1,3}(\+\d{1,2})?'?$/.test(statusLabel) ||
            ["HT", "INT"].includes(status.toUpperCase()) ||
            ["HT", "INT"].includes(statusLabel.toUpperCase()) ||
            /INPROGRESS|LIVE|1ST|2ND|FIRST HALF|SECOND HALF|1H|2H/i.test(joined);
        };
        const liveGames = allGames.filter((game) => {
          return isLiveStatus(game);
        });
        const hiddenGamesCount = Math.max(0, allGames.length - liveGames.length);
      %>
      <section class="panel sofascore-result <%= latestSnapshot.ok ? 'is-ok' : 'is-error' %>">
        <div class="account-section-head">
          <div>
            <p class="eyebrow">Cache atual</p>
            <h2><%= latestSnapshot.ok ? "Monitor atualizado" : "Monitor com erro" %></h2>
          </div>
          <span class="badge <%= latestSnapshot.ok ? 'paid' : 'canceled' %>"><%= latestSnapshot.ok ? "OK" : "Erro" %></span>
        </div>

        <div class="account-stats sofascore-result-stats">
          <article>
            <span>Finalizado em</span>
            <strong><%= formatDateTime(latestSnapshot.finishedAt) %></strong>
          </article>
          <article>
            <span>Texto lido</span>
            <strong><%= latestSnapshot.textLength || 0 %></strong>
            <small>caracteres visiveis</small>
          </article>
          <article>
            <span>Jogos ao vivo</span>
            <strong><%= liveGames.length %></strong>
            <small>de <%= latestSnapshot.gamesCount || allGames.length || 0 %> capturados</small>
          </article>
        </div>

        <% if (latestSnapshot.error) { %>
          <div class="flash error"><p><%= latestSnapshot.error %></p></div>
        <% } %>

        <div class="sofascore-result-grid">
          <article>
            <h3>Pagina capturada</h3>
            <p><strong>Titulo:</strong> <%= latestSnapshot.title || "-" %></p>
            <p><strong>URL:</strong> <%= latestSnapshot.currentUrl || latestSnapshot.sourceUrl %></p>
          </article>

          <article>
            <div class="sofascore-cache-head">
              <div>
                <h3>Jogos ao vivo no cache</h3>
                <p class="muted">Usados no funil de entradas ao vivo.</p>
              </div>
              <% if (hiddenGamesCount) { %>
                <span class="badge"><%= hiddenGamesCount %> agendados/finalizados ocultos</span>
              <% } %>
            </div>
            <% if (liveGames.length) { %>
              <div class="sofascore-game-grid">
                <% liveGames.forEach((game) => {
                  const stats = game.stats || {};
                  const statsTotal = Number(stats.totalShots || 0) + Number(stats.shotsOnTarget || 0) + Number(stats.corners || 0) + Number(stats.dangerousAttacks || 0);
                  const hasRealStats = !stats.estimated && !stats.unavailable;
                  const hasOdds = game.odds1x2 && (game.odds1x2.home || game.odds1x2.draw || game.odds1x2.away);
                  const displayStatus = isLiveStatus(game) ? (game.statusLabel === "Intervalo" || ["HT", "INT"].includes(String(game.status || "").toUpperCase()) ? "Intervalo" : "Ao vivo") : game.statusLabel || game.status || "Ao vivo";
                %>
                  <div class="sofascore-game-card">
                    <div class="sofascore-game-title">
                      <strong><%= game.homeTeam %> x <%= game.awayTeam %></strong>
                      <span class="badge paid"><%= displayStatus %></span>
                    </div>
                    <p class="muted"><%= game.competition || "SofaScore" %><%= game.group ? ` - ${game.group}` : "" %></p>
                    <dl class="sofascore-game-metrics">
                      <div>
                        <dt>Horario</dt>
                        <dd><%= game.time || "-" %></dd>
                      </div>
                      <div>
                        <dt>Minuto</dt>
                        <dd><%= game.minute || "-" %></dd>
                      </div>
                      <div>
                        <dt>Placar</dt>
                        <dd><%= game.score || "-" %></dd>
                      </div>
                    </dl>
                    <% if (hasOdds) { %>
                      <div class="sofascore-odds-row">
                        <span>1 <strong><%= game.odds1x2.home || "-" %></strong></span>
                        <span>X <strong><%= game.odds1x2.draw || "-" %></strong></span>
                        <span>2 <strong><%= game.odds1x2.away || "-" %></strong></span>
                      </div>
                    <% } %>
                    <% if (hasRealStats || statsTotal > 0) { %>
                      <dl class="sofascore-stats-row">
                        <div><dt>Finalizacoes</dt><dd><%= stats.totalShots || 0 %></dd></div>
                        <div><dt>No alvo</dt><dd><%= stats.shotsOnTarget || 0 %></dd></div>
                        <div><dt>Escanteios</dt><dd><%= stats.corners || 0 %></dd></div>
                        <div><dt>Ataques</dt><dd><%= stats.dangerousAttacks || 0 %></dd></div>
                      </dl>
                    <% } else { %>
                      <p class="muted">Estatisticas reais ainda nao disponiveis para esta partida.</p>
                    <% } %>
                  </div>
                <% }) %>
              </div>
            <% } else if (allGames.length) { %>
              <p class="muted">A leitura capturou <%= allGames.length %> jogos, mas nenhum estava ao vivo. Eles ficaram fora do funil.</p>
            <% } else { %>
              <p class="muted">Nenhum jogo estruturado foi salvo. Confira as linhas brutas abaixo.</p>
            <% } %>
          </article>
        </div>

        <details class="sofascore-raw-lines">
          <summary>Ver linhas brutas capturadas</summary>
          <pre><%= (latestSnapshot.lines || []).slice(0, 120).join("\n") %></pre>
        </details>
      </section>
    <% } %>

    <section class="table-panel sofascore-history-panel">
      <h2>Ultimas leituras salvas</h2>
      <table>
        <thead>
          <tr>
            <th>Data</th>
            <th>Status</th>
            <th>Jogos</th>
            <th>URL</th>
            <th>Erro</th>
          </tr>
        </thead>
        <tbody>
          <% if (!snapshots.length) { %>
            <tr><td colspan="5">Nenhuma leitura salva ainda.</td></tr>
          <% } %>
          <% snapshots.forEach((snapshot) => { %>
            <tr>
              <td><%= formatDateTime(snapshot.finishedAt || snapshot.createdAt) %></td>
              <td><span class="badge <%= snapshot.ok ? 'paid' : 'canceled' %>"><%= snapshot.ok ? "OK" : "Erro" %></span></td>
              <td><strong><%= snapshot.gamesCount || snapshot.games?.length || 0 %></strong></td>
              <td><small><%= snapshot.currentUrl || snapshot.sourceUrl || "-" %></small></td>
              <td><small><%= snapshot.error || "-" %></small></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </section>
  </div>
</section>
<%- include("../partials/footer") %>
