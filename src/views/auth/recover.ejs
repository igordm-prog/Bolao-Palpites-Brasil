<%- include("../partials/head", { title }) %>
<section class="auth-shell">
  <form class="panel form recover-card" action="/recuperar" method="post">
    <p class="eyebrow">Acesso seguro</p>
    <h1>Recuperar senha</h1>
    <p class="muted">Escolha como quer confirmar sua identidade. O codigo sera enviado para o e-mail cadastrado e tem validade de 15 minutos.</p>

    <div class="recovery-methods" role="tablist" aria-label="Metodo de recuperacao">
      <label class="recovery-method active">
        <input type="radio" name="method" value="email" checked>
        <strong>E-mail</strong>
        <span>Receba um codigo no e-mail cadastrado.</span>
      </label>
      <label class="recovery-method">
        <input type="radio" name="method" value="cpf">
        <strong>CPF</strong>
        <span>Informe o CPF e enviaremos para o e-mail cadastrado.</span>
      </label>
    </div>

    <label>
      <span id="recovery-label">E-mail cadastrado</span>
      <input id="recovery-identifier" type="email" name="identifier" autocomplete="email" placeholder="voce@email.com" required>
    </label>

    <button class="button full" type="submit">Enviar codigo</button>
    <p class="muted">Enquanto o SMTP nao estiver configurado, o codigo de teste aparece na tela. Depois da configuracao, ele sera enviado por e-mail.</p>
  </form>
</section>
<script>
  (() => {
    const options = document.querySelectorAll('.recovery-method input[name="method"]');
    const label = document.getElementById("recovery-label");
    const input = document.getElementById("recovery-identifier");
    const config = {
      email: { label: "E-mail cadastrado", type: "email", inputmode: "email", placeholder: "voce@email.com", autocomplete: "email", maxLength: 254 },
      cpf: { label: "CPF cadastrado", type: "text", inputmode: "numeric", placeholder: "000.000.000-00", autocomplete: "off", maxLength: 14 }
    };

    function onlyDigits(value) {
      return value.replace(/\D/g, "");
    }

    function maskCpf(value) {
      const digits = onlyDigits(value).slice(0, 11);
      return digits
        .replace(/^(\d{3})(\d)/, "$1.$2")
        .replace(/^(\d{3})\.(\d{3})(\d)/, "$1.$2.$3")
        .replace(/^(\d{3})\.(\d{3})\.(\d{3})(\d)/, "$1.$2.$3-$4");
    }

    function updateMethod(method) {
      const settings = config[method] || config.email;
      label.textContent = settings.label;
      input.value = "";
      input.type = settings.type;
      input.inputMode = settings.inputmode;
      input.placeholder = settings.placeholder;
      input.autocomplete = settings.autocomplete;
      input.maxLength = settings.maxLength;
      document.querySelectorAll(".recovery-method").forEach((item) => {
        item.classList.toggle("active", item.querySelector("input").checked);
      });
    }

    options.forEach((option) => {
      option.addEventListener("change", () => updateMethod(option.value));
    });

    input.addEventListener("input", () => {
      const method = document.querySelector('.recovery-method input[name="method"]:checked')?.value;
      if (method === "cpf") input.value = maskCpf(input.value);
    });
  })();
</script>
<%- include("../partials/footer") %>
