<%- include("../partials/head", { title }) %>
<section class="workspace">
  <aside class="sidebar">
    <h2>Carteira</h2>
    <a href="/app/conta">Resumo</a>
    <a class="active" href="/app/carteira">Carteira</a>
    <a href="/app/perfil">Perfil</a>
  </aside>
  <div class="content">
    <div class="section-header">
      <div>
        <p class="eyebrow">Saldo do usuario</p>
        <h1>Minha carteira</h1>
      </div>
      <div class="wallet">
        <span>Disponivel</span>
        <strong><%= formatMoney(user.walletBalance) %></strong>
        <small>Saque minimo: <%= formatMoney(settings.withdrawalMinimum) %></small>
      </div>
    </div>

    <div class="grid wallet-grid">
      <form class="panel form" action="/app/carteira/depositos" method="post">
        <h2>Depositar saldo</h2>
        <p class="muted">Informe o valor e gere o PIX. Quando o Asaas confirmar o pagamento, o saldo entra automaticamente na carteira.</p>
        <label>Valor do deposito
          <input type="number" name="amount" min="<%= settings.depositMinimum %>" step="0.01" value="<%= settings.depositMinimum %>" required>
        </label>
        <% if (!user.billingCpfCnpj && !user.asaasCustomerId) { %>
          <label>CPF ou CNPJ do titular
            <input name="billingCpfCnpj" inputmode="numeric" autocomplete="off" placeholder="Somente numeros" required>
          </label>
          <p class="muted">Este dado e usado apenas para gerar a cobranca PIX no Asaas.</p>
        <% } %>
        <button class="button" type="submit">Gerar PIX para carteira</button>
      </form>

      <form class="panel form" action="/app/carteira/saques" method="post">
        <h2>Solicitar saque</h2>
        <p class="muted">Para sua seguranca, o e-mail da conta precisa estar validado e cada saque exige um codigo enviado por e-mail.</p>
        <label>Valor do saque
          <input type="number" name="amount" min="<%= settings.withdrawalMinimum %>" max="<%= user.walletBalance %>" step="0.01" value="<%= settings.withdrawalMinimum %>" required>
        </label>
        <p class="muted">Destino: <strong><%= user.cpfMasked || "CPF/CNPJ cadastrado" %></strong></p>
        <button class="button secondary" type="submit" <%= Number(user.walletBalance || 0) < Number(settings.withdrawalMinimum || 20) || !user.billingCpfCnpj || !user.emailVerifiedAt ? "disabled" : "" %>>Solicitar saque</button>
        <% if (Number(user.walletBalance || 0) < Number(settings.withdrawalMinimum || 20)) { %>
          <p class="muted">Voce precisa ter pelo menos <%= formatMoney(settings.withdrawalMinimum) %> disponivel para sacar.</p>
        <% } else if (!user.billingCpfCnpj) { %>
          <p class="muted">Para liberar o saque automatico, o CPF/CNPJ do titular precisa estar cadastrado na carteira.</p>
        <% } else if (!user.emailVerifiedAt) { %>
          <p class="muted">Valide o e-mail da conta para liberar solicitacoes de saque.</p>
        <% } %>
      </form>
    </div>

    <% if (!user.emailVerifiedAt) { %>
      <section class="panel form security-panel">
        <div>
          <p class="eyebrow">Validacao obrigatoria</p>
          <h2>Valide seu e-mail para sacar</h2>
          <p class="muted">Enviaremos um codigo de 6 digitos para <strong><%= user.email %></strong>. Depois da validacao, cada saque ainda pedira um novo codigo por seguranca.</p>
        </div>
        <form action="/app/email/verificacao/enviar" method="post">
          <button class="button" type="submit">Enviar codigo por e-mail</button>
        </form>
        <% if (user.emailVerification) { %>
          <form class="inline-code-form" action="/app/email/verificacao/confirmar" method="post">
            <label>Codigo recebido
              <input class="code-input" name="code" inputmode="numeric" autocomplete="one-time-code" placeholder="000000" maxlength="6" required>
            </label>
            <button class="button secondary" type="submit">Validar e-mail</button>
          </form>
        <% } %>
      </section>
    <% } else { %>
      <section class="panel security-panel verified">
        <div>
          <p class="eyebrow">E-mail validado</p>
          <h2>Saques protegidos por codigo</h2>
          <p class="muted">A conta esta pronta para saque. Ao solicitar, o sistema enviara um codigo para confirmar a transferencia.</p>
        </div>
      </section>
    <% } %>

    <div class="grid wallet-grid">
      <article class="panel">
        <h2>Como a entrada funciona</h2>
        <dl class="details">
          <div><dt>1. Deposito</dt><dd>Voce adiciona saldo por PIX.</dd></div>
          <div><dt>2. Confirmacao</dt><dd>O Asaas confirma e o valor entra na carteira.</dd></div>
          <div><dt>3. Participacao</dt><dd>Ao clicar em participar, a entrada e descontada automaticamente.</dd></div>
        </dl>
      </article>

      <article class="panel">
        <h2>Como o saque funciona</h2>
        <dl class="details">
          <div><dt>1. Validacao</dt><dd>O e-mail da conta precisa estar confirmado.</dd></div>
          <div><dt>2. Codigo</dt><dd>Cada solicitacao exige codigo enviado por e-mail.</dd></div>
          <div><dt>3. Pagamento</dt><dd>Apos confirmar, o PIX e enviado ao CPF/CNPJ cadastrado.</dd></div>
        </dl>
      </article>
    </div>

    <section class="table-panel">
      <h2>Movimentacoes</h2>
      <table>
        <thead><tr><th>Tipo</th><th>Valor</th><th>Status</th><th>Metodo</th><th>Data</th><th>Acao</th></tr></thead>
        <tbody>
          <% if (!payments.length) { %>
            <tr><td colspan="6">Nenhuma movimentacao ainda.</td></tr>
          <% } %>
          <% payments.forEach((payment) => { %>
            <tr>
              <td><%= labelForPaymentType(payment.type) %></td>
              <td><%= formatMoney(payment.amount) %></td>
              <td><span class="badge <%= payment.status %>"><%= labelForStatus(payment.status) %></span></td>
              <td><%= labelForPaymentMethod(payment.method) %></td>
              <td><%= formatDateTime(payment.createdAt) %></td>
              <td>
                <% if (payment.type === "deposit" && payment.status === "awaiting") { %>
                  <a class="button small" href="/app/pagamentos/<%= payment.id %>">Ver PIX</a>
                <% } else if (payment.type === "withdrawal" && payment.status === "awaiting") { %>
                  Aguardando saque
                <% } else { %>
                  -
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </section>
  </div>
</section>
<script>
  (() => {
    document.querySelectorAll(".code-input").forEach((input) => {
      input.addEventListener("input", () => {
        input.value = input.value.replace(/\D/g, "").slice(0, 6);
      });
    });
  })();
</script>
<%- include("../partials/footer") %>
