<%- include("../partials/head", { title }) %>
<section class="narrow">
  <p class="eyebrow">Deposito na carteira</p>
  <h1><%= payment.type === "deposit" ? "PIX para adicionar saldo" : pool.name %></h1>
  <dl class="details">
    <div><dt>Valor</dt><dd><%= formatMoney(payment.amount) %></dd></div>
    <div><dt>Status</dt><dd><span class="badge"><%= labelForStatus(payment.status) %></span></dd></div>
    <div><dt>Metodo</dt><dd><%= labelForPaymentMethod(payment.method) %></dd></div>
  </dl>
  <% if (payment.type === "deposit") { %>
    <div class="pix-box">
      <% if (payment.pixEncodedImage) { %>
        <span>QR Code PIX</span>
        <img class="pix-qr" src="data:image/png;base64,<%= payment.pixEncodedImage %>" alt="QR Code PIX">
      <% } %>
      <span>PIX copia e cola</span>
      <code><%= payment.pixCode %></code>
      <% if (payment.pixExpirationDate) { %>
        <small>Valido ate <%= formatDateTime(payment.pixExpirationDate) %></small>
      <% } %>
    </div>
    <% if (payment.invoiceUrl) { %>
      <a class="button" href="<%= payment.invoiceUrl %>" target="_blank" rel="noopener">Abrir cobranca no Asaas</a>
    <% } %>
    <p class="muted">Quando o pagamento for confirmado pelo Asaas, o valor entra automaticamente na sua carteira. A entrada do bolao sera descontada quando voce escolher participar.</p>
  <% } else { %>
    <p class="muted">Esta entrada foi paga com saldo da carteira.</p>
  <% } %>
  <a class="button secondary" href="/app/carteira">Voltar para carteira</a>
</section>
<%- include("../partials/footer") %>
