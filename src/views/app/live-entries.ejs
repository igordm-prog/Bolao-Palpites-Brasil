<%- include("../partials/head", { title }) %>
<section class="workspace account-workspace live-entries-page" data-live-entries-page>
  <aside class="sidebar account-sidebar">
    <h2>Entradas</h2>
    <a class="active" href="/app/entradas-ao-vivo">Entradas ao vivo</a>
    <a href="/app/boloes">Jogos</a>
    <a href="/app/conta">Conta</a>
    <a href="/app/historico">Historico</a>
  </aside>

  <div class="content account-content">
    <header class="account-hero live-entries-hero">
      <div>
        <p class="eyebrow">Alertas manuais</p>
        <h1>Entradas ao vivo</h1>
        <p>Monitoramento de jogos em andamento com estatisticas reais do SofaScore e funis de analise manual.</p>
        <% if (liveEntries.isDemo) { %>
          <p class="muted">Configure a chave API_FOOTBALL_KEY para substituir a demonstracao por jogos ao vivo reais.</p>
        <% } %>
      </div>
      <div class="account-wallet live-source-card">
        <span>Fonte ativa</span>
        <strong data-provider-label><%= liveEntries.providerLabel %></strong>
        <small data-last-update>
          <% if (liveEntries.updatedAt) { %>
            Atualizado em <%= formatDateTime(liveEntries.updatedAt) %>
          <% } else { %>
            Aguardando primeira leitura
          <% } %>
        </small>
        <div class="account-actions">
          <button class="button small" type="button" data-refresh-live>Atualizar</button>
        </div>
      </div>
    </header>

    <% if (liveEntries.error) { %>
      <section class="flash error live-error" data-live-error><p><%= liveEntries.error %></p></section>
    <% } else { %>
      <section class="flash error live-error" data-live-error hidden></section>
    <% } %>

    <div class="account-stats live-entry-stats">
      <article>
        <span>Jogos monitorados</span>
        <strong data-stat-matches><%= liveEntries.stats.matches %></strong>
        <small>ao vivo ou em observacao</small>
      </article>
      <article>
        <span>Sinais encontrados</span>
        <strong data-stat-signals><%= liveEntries.stats.signals %></strong>
        <small>alertas aprovados no funil</small>
      </article>
      <article>
        <span>Com estatisticas</span>
        <strong data-stat-with-stats><%= liveEntries.stats.withStats || 0 %></strong>
        <small>dados reais disponiveis</small>
      </article>
      <article>
        <span>Selecionados</span>
        <strong data-stat-monitored><%= liveEntries.stats.monitored || liveEntries.monitoredCount || 0 %></strong>
        <small>captura profunda ativa</small>
      </article>
    </div>

    <section class="account-section">
      <div class="account-section-head">
        <div>
          <p class="eyebrow">Alertas</p>
          <h2>Entradas encontradas</h2>
        </div>
        <span class="muted">Robo a cada 60s. Tela a cada 30s.</span>
      </div>
      <div class="live-signal-grid" data-signals-list>
        <% if (!liveEntries.signals.length) { %>
          <article class="pool-item single live-empty-state">
            <div>
              <h3>Nenhuma entrada no funil agora</h3>
              <p class="muted">Quando um jogo bater os filtros obrigatorios, ele aparecera aqui para analise manual.</p>
            </div>
          </article>
        <% } %>
        <% liveEntries.signals.forEach((signal) => { %>
          <article class="live-signal-card">
            <div class="live-signal-head">
              <div>
                <p class="live-entry-kicker">Entrada encontrada</p>
                <h3><%= signal.alert?.entrada || signal.recommendation?.market || "Alerta" %></h3>
                <p>Analisar manualmente antes de qualquer decisao.</p>
              </div>
              <span class="live-score-badge"><small>Tempo</small><strong><%= signal.alert?.tempo || `${signal.minute}'` %></strong></span>
            </div>
            <div class="live-match-line">
              <div>
                <strong><%= signal.homeTeam %> x <%= signal.awayTeam %></strong>
                <small><%= signal.league %></small>
              </div>
              <div>
                <strong><%= signal.scoreboard %></strong>
                <small><%= signal.minute %>'</small>
              </div>
            </div>
            <dl class="live-signal-metrics">
              <div><dt>PXG</dt><dd><%= signal.pxg?.approved ? "Confirmado" : "Monitorando" %></dd></div>
              <div><dt>CG</dt><dd><%= signal.sideStats ? ((signal.sideStats.totalShots || 0) + (signal.sideStats.shotsOnTarget || 0) + (signal.sideStats.corners || 0)) : 0 %></dd></div>
              <div><dt>xG lado</dt><dd><%= Number(signal.sideStats?.xg || 0).toFixed(2) %></dd></div>
            </dl>
            <ul class="live-reasons">
              <% signal.reasons.slice(0, 5).forEach((reason) => { %><li><%= reason %></li><% }) %>
            </ul>
            <a class="button full" href="<%= signal.link %>" target="_blank" rel="noreferrer">Abrir no SofaScore</a>
          </article>
        <% }) %>
      </div>
    </section>

    <section class="table-panel live-matches-panel">
      <h2>Todos os jogos em monitoramento</h2>
      <div class="live-match-list" data-matches-body>
        <% if (!liveEntries.matches.length) { %>
          <article class="pool-item single live-empty-state">
            <div>
              <h3>Nenhum jogo ao vivo encontrado agora.</h3>
            </div>
          </article>
        <% } %>
        <% liveEntries.matches.forEach((match) => { %>
          <% const statsRows = [
            ["Posse de bola", `${match.stats.possessionHome || 0}%`, `${match.stats.possessionAway || 0}%`, match.stats.possessionHome || 0, match.stats.possessionAway || 0],
            ["Gols esperados (xG)", Number(match.stats.expectedGoalsHome || 0).toFixed(2), Number(match.stats.expectedGoalsAway || 0).toFixed(2), match.stats.expectedGoalsHome || 0, match.stats.expectedGoalsAway || 0],
            ["Finalizacoes", match.stats.homeTotalShots || 0, match.stats.awayTotalShots || 0, match.stats.homeTotalShots || 0, match.stats.awayTotalShots || 0],
            ["No alvo", match.stats.homeShotsOnTarget || 0, match.stats.awayShotsOnTarget || 0, match.stats.homeShotsOnTarget || 0, match.stats.awayShotsOnTarget || 0],
            ["Escanteios", match.stats.homeCorners || 0, match.stats.awayCorners || 0, match.stats.homeCorners || 0, match.stats.awayCorners || 0],
            ["Cartoes", (match.stats.yellowCards || 0) + (match.stats.redCards || 0), "-", 0, 0]
          ]; %>
          <details class="live-match-card">
            <summary class="live-match-summary">
              <div>
                <strong><%= match.homeTeam %> x <%= match.awayTeam %></strong>
                <small><%= match.league %></small>
              </div>
              <div class="live-match-score">
                <strong><%= match.scoreboard %></strong>
                <small><%= match.sofaScoreStatus || `${match.minute}'` %></small>
              </div>
              <span class="badge <%= match.alert ? 'paid' : 'awaiting' %>"><%= match.status %></span>
            </summary>
            <div class="live-match-expanded">
              <div class="live-expanded-head">
                <div>
                  <span><%= match.homeTeam %></span>
                  <strong><%= match.homeScore ?? "" %></strong>
                </div>
                <div>
                  <small><%= match.statsEstimated ? "Sem estatisticas reais do SofaScore" : "Estatisticas reais do SofaScore" %></small>
                  <strong><%= match.scoreboard %></strong>
                </div>
                <div>
                  <span><%= match.awayTeam %></span>
                  <strong><%= match.awayScore ?? "" %></strong>
                </div>
              </div>
              <div class="live-sofascore-stats">
                <% statsRows.forEach((row) => { %>
                  <% const total = Number(row[3] || 0) + Number(row[4] || 0); const homePct = total ? Math.round((Number(row[3] || 0) / total) * 100) : 50; const awayPct = total ? 100 - homePct : 50; %>
                  <div class="live-stat-row">
                    <strong><%= row[1] %></strong>
                    <div>
                      <span><%= row[0] %></span>
                      <div class="live-stat-bars">
                        <i style="width:<%= homePct %>%"></i>
                        <b style="width:<%= awayPct %>%"></b>
                      </div>
                    </div>
                    <strong><%= row[2] %></strong>
                  </div>
                <% }) %>
              </div>
              <div class="live-decision-panel">
                <div>
                  <strong><%= match.alert?.entrada || "Monitorando" %></strong>
                  <small><%= match.statsMonitoring ? "Estatisticas reais sendo recapturadas a cada ciclo." : "Selecione o jogo para capturar estatisticas reais." %></small>
                </div>
                <div class="live-monitor-actions">
                  <% if (liveEntries.canManageMonitoring && match.eventId) { %>
                    <button
                      class="button small <%= match.statsMonitoring ? 'secondary' : '' %>"
                      type="button"
                      data-monitor-stats
                      data-event-id="<%= match.eventId %>"
                      data-active="<%= match.statsMonitoring ? 'true' : 'false' %>">
                      <%= match.statsMonitoring ? "Parar estatisticas" : "Monitorar estatisticas" %>
                    </button>
                  <% } else if (match.statsMonitoring) { %>
                    <span class="badge paid">Monitorado</span>
                  <% } %>
                  <a class="button small secondary" href="<%= match.link %>" target="_blank" rel="noreferrer">Abrir no SofaScore</a>
                </div>
              </div>
            </div>
          </details>
        <% }) %>
      </div>
    </section>
  </div>
</section>

<script>
  (() => {
    const root = document.querySelector("[data-live-entries-page]");
    if (!root) return;

    const signalsList = root.querySelector("[data-signals-list]");
    const matchesBody = root.querySelector("[data-matches-body]");
    const errorBox = root.querySelector("[data-live-error]");
    const refreshButton = root.querySelector("[data-refresh-live]");
    const providerLabel = root.querySelector("[data-provider-label]");
    const lastUpdate = root.querySelector("[data-last-update]");
    const statMatches = root.querySelector("[data-stat-matches]");
    const statSignals = root.querySelector("[data-stat-signals]");
    const statWithStats = root.querySelector("[data-stat-with-stats]");
    const statMonitored = root.querySelector("[data-stat-monitored]");

    function escapeHtml(value) {
      return String(value ?? "").replace(/[&<>"']/g, (char) => ({
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#039;"
      })[char]);
    }

    function cg(match) {
      return (match.sideStats?.totalShots || 0) + (match.sideStats?.shotsOnTarget || 0) + (match.sideStats?.corners || 0);
    }

    function statRows(match) {
      const stats = match.stats || {};
      return [
        ["Posse de bola", `${stats.possessionHome || 0}%`, `${stats.possessionAway || 0}%`, stats.possessionHome || 0, stats.possessionAway || 0],
        ["Gols esperados (xG)", Number(stats.expectedGoalsHome || 0).toFixed(2), Number(stats.expectedGoalsAway || 0).toFixed(2), stats.expectedGoalsHome || 0, stats.expectedGoalsAway || 0],
        ["Finalizacoes", stats.homeTotalShots || 0, stats.awayTotalShots || 0, stats.homeTotalShots || 0, stats.awayTotalShots || 0],
        ["No alvo", stats.homeShotsOnTarget || 0, stats.awayShotsOnTarget || 0, stats.homeShotsOnTarget || 0, stats.awayShotsOnTarget || 0],
        ["Escanteios", stats.homeCorners || 0, stats.awayCorners || 0, stats.homeCorners || 0, stats.awayCorners || 0],
        ["Cartoes", (stats.yellowCards || 0) + (stats.redCards || 0), "-", 0, 0]
      ];
    }

    function statRowHtml(row) {
      const total = Number(row[3] || 0) + Number(row[4] || 0);
      const homePct = total ? Math.round((Number(row[3] || 0) / total) * 100) : 50;
      const awayPct = total ? 100 - homePct : 50;
      return `
        <div class="live-stat-row">
          <strong>${escapeHtml(row[1])}</strong>
          <div>
            <span>${escapeHtml(row[0])}</span>
            <div class="live-stat-bars">
              <i style="width:${homePct}%"></i>
              <b style="width:${awayPct}%"></b>
            </div>
          </div>
          <strong>${escapeHtml(row[2])}</strong>
        </div>
      `;
    }

    function monitorActionHtml(match, data) {
      if (data.canManageMonitoring && match.eventId) {
        const active = Boolean(match.statsMonitoring);
        return `
          <button
            class="button small ${active ? "secondary" : ""}"
            type="button"
            data-monitor-stats
            data-event-id="${escapeHtml(match.eventId)}"
            data-active="${active ? "true" : "false"}">
            ${active ? "Parar estatisticas" : "Monitorar estatisticas"}
          </button>
        `;
      }
      if (match.statsMonitoring) return `<span class="badge paid">Monitorado</span>`;
      return "";
    }

    function render(data) {
      providerLabel.textContent = data.providerLabel || "Demonstracao";
      lastUpdate.textContent = data.updatedAt ? `Atualizado em ${new Date(data.updatedAt).toLocaleString("pt-BR")}` : "Aguardando primeira leitura";
      statMatches.textContent = data.stats.matches;
      statSignals.textContent = data.stats.signals;
      statWithStats.textContent = data.stats.withStats || 0;
      statMonitored.textContent = data.stats.monitored || data.monitoredCount || 0;

      if (data.error) {
        errorBox.hidden = false;
        errorBox.innerHTML = `<p>${escapeHtml(data.error)}</p>`;
      } else {
        errorBox.hidden = true;
        errorBox.innerHTML = "";
      }

      signalsList.innerHTML = data.signals.length ? data.signals.map((signal) => `
        <article class="live-signal-card">
          <div class="live-signal-head">
            <div>
              <p class="live-entry-kicker">Entrada encontrada</p>
              <h3>${escapeHtml(signal.alert?.entrada || signal.recommendation?.market || "Alerta")}</h3>
              <p>Analisar manualmente antes de qualquer decisao.</p>
            </div>
            <span class="live-score-badge"><small>Tempo</small><strong>${escapeHtml(signal.alert?.tempo || `${signal.minute}'`)}</strong></span>
          </div>
          <div class="live-match-line">
            <div>
              <strong>${escapeHtml(signal.homeTeam)} x ${escapeHtml(signal.awayTeam)}</strong>
              <small>${escapeHtml(signal.league)}</small>
            </div>
            <div>
              <strong>${escapeHtml(signal.scoreboard)}</strong>
              <small>${signal.minute}'</small>
            </div>
          </div>
          <dl class="live-signal-metrics">
            <div><dt>PXG</dt><dd>${signal.pxg?.approved ? "Confirmado" : "Monitorando"}</dd></div>
            <div><dt>CG</dt><dd>${cg(signal)}</dd></div>
            <div><dt>xG lado</dt><dd>${Number(signal.sideStats?.xg || 0).toFixed(2)}</dd></div>
          </dl>
          <ul class="live-reasons">${signal.reasons.slice(0, 5).map((reason) => `<li>${escapeHtml(reason)}</li>`).join("")}</ul>
          <a class="button full" href="${escapeHtml(signal.link)}" target="_blank" rel="noreferrer">Abrir no SofaScore</a>
        </article>
      `).join("") : `
        <article class="pool-item single live-empty-state">
          <div>
            <h3>Nenhuma entrada no funil agora</h3>
            <p class="muted">Quando um jogo bater os filtros obrigatorios, ele aparecera aqui para analise manual.</p>
          </div>
        </article>
      `;

      matchesBody.innerHTML = data.matches.length ? data.matches.map((match) => `
        <details class="live-match-card">
          <summary class="live-match-summary">
            <div>
              <strong>${escapeHtml(match.homeTeam)} x ${escapeHtml(match.awayTeam)}</strong>
              <small>${escapeHtml(match.league)}</small>
            </div>
            <div class="live-match-score">
              <strong>${escapeHtml(match.scoreboard)}</strong>
              <small>${escapeHtml(match.sofaScoreStatus || `${match.minute}'`)}</small>
            </div>
            <span class="badge ${match.alert ? "paid" : "awaiting"}">${escapeHtml(match.status)}</span>
          </summary>
          <div class="live-match-expanded">
            <div class="live-expanded-head">
              <div>
                <span>${escapeHtml(match.homeTeam)}</span>
                <strong>${escapeHtml(String(match.homeScore ?? ""))}</strong>
              </div>
              <div>
                <small>${match.statsEstimated ? "Sem estatisticas reais do SofaScore" : "Estatisticas reais do SofaScore"}</small>
                <strong>${escapeHtml(match.scoreboard)}</strong>
              </div>
              <div>
                <span>${escapeHtml(match.awayTeam)}</span>
                <strong>${escapeHtml(String(match.awayScore ?? ""))}</strong>
              </div>
            </div>
            <div class="live-sofascore-stats">
              ${statRows(match).map(statRowHtml).join("")}
            </div>
            <div class="live-decision-panel">
              <div>
                <strong>${escapeHtml(match.alert?.entrada || "Monitorando")}</strong>
                <small>${escapeHtml(match.statsMonitoring ? "Estatisticas reais sendo recapturadas a cada ciclo." : "Selecione o jogo para capturar estatisticas reais.")}</small>
              </div>
              <div class="live-monitor-actions">
                ${monitorActionHtml(match, data)}
                <a class="button small secondary" href="${escapeHtml(match.link)}" target="_blank" rel="noreferrer">Abrir no SofaScore</a>
              </div>
            </div>
          </div>
        </details>
      `).join("") : `
        <article class="pool-item single live-empty-state">
          <div><h3>Nenhum jogo ao vivo encontrado agora.</h3></div>
        </article>
      `;
    }

    async function load(force = false) {
      const url = force ? "/app/entradas-ao-vivo/atualizar" : "/app/entradas-ao-vivo/dados";
      const response = await fetch(url, { method: force ? "POST" : "GET" });
      if (!response.ok) throw new Error("Nao foi possivel atualizar as entradas.");
      render(await response.json());
    }

    refreshButton.addEventListener("click", async () => {
      refreshButton.disabled = true;
      try {
        await load(true);
      } finally {
        refreshButton.disabled = false;
      }
    });

    matchesBody.addEventListener("click", async (event) => {
      const button = event.target.closest("[data-monitor-stats]");
      if (!button) return;
      event.preventDefault();
      button.disabled = true;
      try {
        const response = await fetch("/app/entradas-ao-vivo/monitorar", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            eventId: button.dataset.eventId,
            action: button.dataset.active === "true" ? "remove" : "add"
          })
        });
        if (!response.ok) throw new Error("Nao foi possivel alterar o monitoramento.");
        render(await response.json());
      } finally {
        button.disabled = false;
      }
    });

    window.setInterval(() => load(false).catch(() => {}), 30000);
  })();
</script>
<%- include("../partials/footer") %>
