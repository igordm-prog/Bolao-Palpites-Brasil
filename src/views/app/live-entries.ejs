<%- include("../partials/head", { title }) %>
<section class="workspace account-workspace live-entries-page" data-live-entries-page data-can-manage="<%= canManageLiveEntries ? 'true' : 'false' %>">
  <aside class="sidebar account-sidebar">
    <h2>Entradas</h2>
    <a class="active" href="/app/entradas-ao-vivo">Entradas ao vivo</a>
    <a href="/app/boloes">Jogos</a>
    <a href="/app/conta">Conta</a>
    <a href="/app/historico">Historico</a>
  </aside>

  <div class="content account-content">
    <header class="account-hero live-entries-hero">
      <div>
        <p class="eyebrow">Over 1.5 gols</p>
        <h1>Entradas ao vivo</h1>
        <p>Monitoramento de jogos em andamento com funil estatistico, score de entrada e link manual para Betano.</p>
        <% if (liveEntries.isDemo) { %>
          <p class="muted">Configure a chave API_FOOTBALL_KEY para substituir a demonstracao por jogos ao vivo reais.</p>
        <% } %>
      </div>
      <div class="account-wallet live-source-card">
        <span>Fonte ativa</span>
        <strong data-provider-label><%= liveEntries.providerLabel %></strong>
        <small data-last-update>
          <% if (liveEntries.updatedAt) { %>
            Atualizado em <%= formatDateTime(liveEntries.updatedAt) %>
          <% } else { %>
            Aguardando primeira leitura
          <% } %>
        </small>
        <div class="account-actions">
          <button class="button small" type="button" data-refresh-live>Atualizar</button>
          <a class="button secondary small" href="<%= sofaScoreUrl %>" target="_blank" rel="noreferrer">SofaScore</a>
          <a class="button secondary small" href="<%= liveEntries.betanoUrl %>" target="_blank" rel="noreferrer">Betano</a>
        </div>
      </div>
    </header>

    <% if (liveEntries.error) { %>
      <section class="flash error live-error" data-live-error><p><%= liveEntries.error %></p></section>
    <% } else { %>
      <section class="flash error live-error" data-live-error hidden></section>
    <% } %>

    <% if (canManageLiveEntries) { %>
      <section class="panel live-manual-panel">
        <div class="account-section-head">
          <div>
            <p class="eyebrow">Modo manual assistido</p>
            <h2>Adicionar jogo observado</h2>
            <p class="muted">Abra o SofaScore em outra aba, acompanhe o jogo e lance os dados principais para o funil calcular o score.</p>
          </div>
          <a class="button secondary small" href="<%= sofaScoreUrl %>" target="_blank" rel="noreferrer">Abrir SofaScore</a>
        </div>
        <form class="live-manual-form" action="/app/entradas-ao-vivo/manual" method="post">
          <div class="live-manual-grid">
            <label>Campeonato
              <input type="text" name="league" placeholder="Ex.: Serie A, Copa do Brasil">
            </label>
            <label>Mandante
              <input type="text" name="homeTeam" placeholder="Time da casa" required>
            </label>
            <label>Visitante
              <input type="text" name="awayTeam" placeholder="Time visitante" required>
            </label>
            <label>Minuto
              <input type="number" name="minute" min="1" max="130" placeholder="27" required>
            </label>
            <label>Placar casa
              <input type="number" name="homeScore" min="0" value="0" required>
            </label>
            <label>Placar visitante
              <input type="number" name="awayScore" min="0" value="0" required>
            </label>
            <label>Odd Over 1.5
              <input type="number" name="liveOdd" min="1" max="20" step="0.01" placeholder="1.85">
            </label>
            <label>Link de referencia
              <input type="url" name="referenceUrl" placeholder="https://www.sofascore.com/pt/...">
            </label>
          </div>
          <div class="live-manual-stats">
            <label>Finalizacoes <input type="number" name="totalShots" min="0" value="0"></label>
            <label>No alvo <input type="number" name="shotsOnTarget" min="0" value="0"></label>
            <label>Escanteios <input type="number" name="corners" min="0" value="0"></label>
            <label>Ataques perigosos <input type="number" name="dangerousAttacks" min="0" value="0"></label>
            <label>Posse casa % <input type="number" name="possessionHome" min="0" max="100" value="50"></label>
            <label>Amarelos <input type="number" name="yellowCards" min="0" value="0"></label>
            <label>Vermelhos <input type="number" name="redCards" min="0" value="0"></label>
          </div>
          <button class="button" type="submit">Adicionar entrada</button>
        </form>
      </section>
    <% } %>

    <div class="account-stats live-entry-stats">
      <article>
        <span>Jogos monitorados</span>
        <strong data-stat-matches><%= liveEntries.stats.matches %></strong>
        <small>ao vivo ou em observacao</small>
      </article>
      <article>
        <span>Sinais encontrados</span>
        <strong data-stat-signals><%= liveEntries.stats.signals %></strong>
        <small>score acima de 85</small>
      </article>
      <article>
        <span>Melhor score</span>
        <strong data-stat-best-score><%= liveEntries.stats.bestScore %></strong>
        <small>funil Over 1.5</small>
      </article>
    </div>

    <section class="account-section">
      <div class="account-section-head">
        <div>
          <p class="eyebrow">Alertas</p>
          <h2>Entradas encontradas</h2>
        </div>
        <span class="muted">Atualiza automaticamente a cada 30s</span>
      </div>
      <div class="live-signal-grid" data-signals-list>
        <% if (!liveEntries.signals.length) { %>
          <article class="pool-item single live-empty-state">
            <div>
              <h3>Nenhuma entrada no funil agora</h3>
              <p class="muted">Quando um jogo bater os filtros, ele aparecera aqui com odd, motivos e link Betano.</p>
            </div>
          </article>
        <% } %>
        <% liveEntries.signals.forEach((signal) => { %>
          <article class="live-signal-card">
            <div class="live-signal-head">
              <div>
                <strong><%= signal.homeTeam %> x <%= signal.awayTeam %></strong>
                <small><%= signal.league %> | <%= signal.minute %>' | <%= signal.scoreboard %></small>
              </div>
              <span class="live-score-badge"><%= signal.funnelScore %></span>
            </div>
            <dl class="live-signal-metrics">
              <div><dt>Odd</dt><dd><%= signal.liveOdd %></dd></div>
              <div><dt>Finalizacoes</dt><dd><%= signal.stats.totalShots %></dd></div>
              <div><dt>Escanteios</dt><dd><%= signal.stats.corners %></dd></div>
            </dl>
            <ul class="live-reasons">
              <% signal.reasons.slice(0, 5).forEach((reason) => { %><li><%= reason %></li><% }) %>
            </ul>
            <div class="live-table-actions">
              <a class="button full" href="<%= signal.link %>" target="_blank" rel="noreferrer"><%= signal.source === "manual" && signal.referenceUrl ? "Abrir referencia" : "Abrir na Betano" %></a>
              <% if (canManageLiveEntries && signal.source === "manual") { %>
                <form action="/app/entradas-ao-vivo/manual/<%= signal.manualEntryId %>/excluir" method="post">
                  <button class="button secondary full" type="submit">Remover</button>
                </form>
              <% } %>
            </div>
          </article>
        <% }) %>
      </div>
    </section>

    <section class="table-panel live-matches-panel">
      <h2>Todos os jogos em monitoramento</h2>
      <table>
        <thead>
          <tr>
            <th>Jogo</th>
            <th>Campeonato</th>
            <th>Status</th>
            <th>Placar</th>
            <th>Odd</th>
            <th>Score</th>
            <th>Ritmo</th>
            <th></th>
          </tr>
        </thead>
        <tbody data-matches-body>
          <% if (!liveEntries.matches.length) { %>
            <tr><td colspan="8">Nenhum jogo ao vivo encontrado agora.</td></tr>
          <% } %>
          <% liveEntries.matches.forEach((match) => { %>
            <tr>
              <td>
                <strong><%= match.homeTeam %> x <%= match.awayTeam %></strong><br>
                <small><%= match.minute %>' <% if (match.source === "manual") { %>| Manual<% } %></small>
              </td>
              <td><%= match.league %></td>
              <td><span class="badge <%= match.funnelScore >= 85 ? 'paid' : 'awaiting' %>"><%= match.status %></span></td>
              <td><%= match.scoreboard %></td>
              <td><strong><%= match.liveOdd %></strong></td>
              <td><span class="live-score-badge table-score"><%= match.funnelScore %></span><br><small><%= match.classification %></small></td>
              <td><strong><%= match.pressure %></strong><br><small><%= match.stats.totalShots %> fin. | <%= match.stats.shotsOnTarget %> alvo | <%= match.stats.corners %> esc.</small></td>
              <td>
                <div class="live-table-actions">
                  <a class="button small secondary" href="<%= match.link %>" target="_blank" rel="noreferrer"><%= match.source === "manual" && match.referenceUrl ? "Referencia" : "Betano" %></a>
                  <% if (canManageLiveEntries && match.source === "manual") { %>
                    <form action="/app/entradas-ao-vivo/manual/<%= match.manualEntryId %>/excluir" method="post">
                      <button class="button small secondary" type="submit">Remover</button>
                    </form>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </section>
  </div>
</section>

<script>
  (() => {
    const root = document.querySelector("[data-live-entries-page]");
    if (!root) return;

    const signalsList = root.querySelector("[data-signals-list]");
    const matchesBody = root.querySelector("[data-matches-body]");
    const errorBox = root.querySelector("[data-live-error]");
    const refreshButton = root.querySelector("[data-refresh-live]");
    const providerLabel = root.querySelector("[data-provider-label]");
    const lastUpdate = root.querySelector("[data-last-update]");
    const statMatches = root.querySelector("[data-stat-matches]");
    const statSignals = root.querySelector("[data-stat-signals]");
    const statBestScore = root.querySelector("[data-stat-best-score]");
    const canManage = root.dataset.canManage === "true";

    function escapeHtml(value) {
      return String(value ?? "").replace(/[&<>"']/g, (char) => ({
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#039;"
      })[char]);
    }

    function actionButtons(match, full = false) {
      const href = escapeHtml(match.link || match.referenceUrl || "#");
      const label = match.source === "manual" && match.referenceUrl ? "Referencia" : "Betano";
      const buttonClass = full ? "button full" : "button small secondary";
      const remove = canManage && match.source === "manual" && match.manualEntryId
        ? `<form action="/app/entradas-ao-vivo/manual/${Number(match.manualEntryId)}/excluir" method="post"><button class="${buttonClass}" type="submit">Remover</button></form>`
        : "";
      return `<div class="live-table-actions"><a class="${buttonClass}" href="${href}" target="_blank" rel="noreferrer">${full && label === "Betano" ? "Abrir na Betano" : label}</a>${remove}</div>`;
    }

    function render(data) {
      providerLabel.textContent = data.providerLabel || "Demonstracao";
      lastUpdate.textContent = data.updatedAt ? `Atualizado em ${new Date(data.updatedAt).toLocaleString("pt-BR")}` : "Aguardando primeira leitura";
      statMatches.textContent = data.stats.matches;
      statSignals.textContent = data.stats.signals;
      statBestScore.textContent = data.stats.bestScore;

      if (data.error) {
        errorBox.hidden = false;
        errorBox.innerHTML = `<p>${escapeHtml(data.error)}</p>`;
      } else {
        errorBox.hidden = true;
        errorBox.innerHTML = "";
      }

      signalsList.innerHTML = data.signals.length ? data.signals.map((signal) => `
        <article class="live-signal-card">
          <div class="live-signal-head">
            <div>
              <strong>${escapeHtml(signal.homeTeam)} x ${escapeHtml(signal.awayTeam)}</strong>
              <small>${escapeHtml(signal.league)} | ${signal.minute}' | ${escapeHtml(signal.scoreboard)}</small>
            </div>
            <span class="live-score-badge">${signal.funnelScore}</span>
          </div>
          <dl class="live-signal-metrics">
            <div><dt>Odd</dt><dd>${escapeHtml(signal.liveOdd)}</dd></div>
            <div><dt>Finalizacoes</dt><dd>${signal.stats.totalShots}</dd></div>
            <div><dt>Escanteios</dt><dd>${signal.stats.corners}</dd></div>
          </dl>
          <ul class="live-reasons">${signal.reasons.slice(0, 5).map((reason) => `<li>${escapeHtml(reason)}</li>`).join("")}</ul>
          ${actionButtons(signal, true)}
        </article>
      `).join("") : `
        <article class="pool-item single live-empty-state">
          <div>
            <h3>Nenhuma entrada no funil agora</h3>
            <p class="muted">Quando um jogo bater os filtros, ele aparecera aqui com odd, motivos e link Betano.</p>
          </div>
        </article>
      `;

      matchesBody.innerHTML = data.matches.length ? data.matches.map((match) => `
        <tr>
          <td><strong>${escapeHtml(match.homeTeam)} x ${escapeHtml(match.awayTeam)}</strong><br><small>${match.minute}'${match.source === "manual" ? " | Manual" : ""}</small></td>
          <td>${escapeHtml(match.league)}</td>
          <td><span class="badge ${match.funnelScore >= 85 ? "paid" : "awaiting"}">${escapeHtml(match.status)}</span></td>
          <td>${escapeHtml(match.scoreboard)}</td>
          <td><strong>${escapeHtml(match.liveOdd)}</strong></td>
          <td><span class="live-score-badge table-score">${match.funnelScore}</span><br><small>${escapeHtml(match.classification)}</small></td>
          <td><strong>${escapeHtml(match.pressure)}</strong><br><small>${match.stats.totalShots} fin. | ${match.stats.shotsOnTarget} alvo | ${match.stats.corners} esc.</small></td>
          <td>${actionButtons(match)}</td>
        </tr>
      `).join("") : `<tr><td colspan="8">Nenhum jogo ao vivo encontrado agora.</td></tr>`;
    }

    async function load(force = false) {
      const url = force ? "/app/entradas-ao-vivo/atualizar" : "/app/entradas-ao-vivo/dados";
      const response = await fetch(url, { method: force ? "POST" : "GET" });
      if (!response.ok) throw new Error("Nao foi possivel atualizar as entradas.");
      render(await response.json());
    }

    refreshButton.addEventListener("click", async () => {
      refreshButton.disabled = true;
      try {
        await load(true);
      } finally {
        refreshButton.disabled = false;
      }
    });

    window.setInterval(() => load(false).catch(() => {}), 30000);
  })();
</script>
<%- include("../partials/footer") %>
