<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="#071018">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="application-name" content="BPB">
    <title><%= title %> | <%= settings.appName %></title>
    <link rel="icon" type="image/svg+xml" href="/img/brand/favicon.svg">
    <link rel="manifest" href="/site.webmanifest">
    <link rel="stylesheet" href="/css/styles.css?v=20260620-3">
  </head>
  <body>
    <header class="topbar">
      <a class="brand" href="/">
        <img class="brand-logo" src="/img/brand/logo-horizontal.svg" alt="Bolao Palpites Brasil">
      </a>
      <div class="topbar-actions">
        <% if (currentUser) { %>
          <a class="top-wallet-chip mobile-wallet-chip" href="/app/carteira" aria-label="Saldo da carteira">
            <span>Saldo</span>
            <strong><%= formatMoney(currentUser.walletBalance) %></strong>
            <em>Depositar</em>
          </a>
          <details class="notification-menu mobile-notification-menu">
            <summary class="notification-bell" aria-label="Notificacoes">
              <svg class="bell-icon" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M18 8a6 6 0 0 0-12 0c0 7-3 7-3 9h18c0-2-3-2-3-9"></path>
                <path d="M10 21h4"></path>
              </svg>
              <% if (notificationCount) { %><b><%= notificationCount %></b><% } %>
            </summary>
            <div class="notification-popover">
              <strong>Notificacoes</strong>
              <% if (notifications && notifications.length) { %>
                <% notifications.forEach((item) => { %>
                  <a class="notification-item <%= item.tone %>" href="<%= item.href %>">
                    <span><%= item.title %></span>
                    <small><%= item.text %></small>
                  </a>
                <% }) %>
              <% } else { %>
                <p>Tudo em dia por aqui.</p>
              <% } %>
            </div>
          </details>
        <% } %>
        <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="site-menu">
          <span></span>
          <span></span>
          <span></span>
          <b>Menu</b>
        </button>
      </div>
      <nav class="nav" id="site-menu">
        <% if (currentUser) { %>
          <a class="<%= currentPath === '/app/boloes' || (currentPath.startsWith('/app/boloes') && currentPath.includes('/palpites')) ? 'active' : '' %>" href="<%= navGamesHref %>">Jogos</a>
          <a class="<%= currentPath.startsWith('/app/entradas-ao-vivo') ? 'active' : '' %>" href="/app/entradas-ao-vivo">Entradas ao vivo</a>
          <a class="<%= currentPath.includes('/ranking') ? 'active' : '' %>" href="<%= navRankingHref %>">Ranking</a>
          <a class="<%= currentPath === '/regras' ? 'active' : '' %>" href="/regras">Regulamento</a>
          <a class="<%= currentPath === '/premiacoes' ? 'active' : '' %>" href="/premiacoes">Premiacoes</a>
          <% if (isAdmin) { %><a class="<%= currentPath === '/admin/resultados' ? 'active' : '' %>" href="/admin/resultados">Resultados</a><% } %>
          <a class="<%= currentPath.includes('/historico') ? 'active' : '' %>" href="/app/historico">Historico</a>
          <a class="<%= currentPath === '/privacidade' ? 'active' : '' %>" href="/privacidade">Ajuda</a>
          <a class="<%= currentPath === '/app/conta' || currentPath === '/app/carteira' || currentPath === '/app/perfil' ? 'active' : '' %>" href="/app/conta">Conta</a>
          <details class="notification-menu desktop-notification-menu">
            <summary class="notification-bell" aria-label="Notificacoes">
              <svg class="bell-icon" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M18 8a6 6 0 0 0-12 0c0 7-3 7-3 9h18c0-2-3-2-3-9"></path>
                <path d="M10 21h4"></path>
              </svg>
              <% if (notificationCount) { %><b><%= notificationCount %></b><% } %>
            </summary>
            <div class="notification-popover">
              <strong>Notificacoes</strong>
              <% if (notifications && notifications.length) { %>
                <% notifications.forEach((item) => { %>
                  <a class="notification-item <%= item.tone %>" href="<%= item.href %>">
                    <span><%= item.title %></span>
                    <small><%= item.text %></small>
                  </a>
                <% }) %>
              <% } else { %>
                <p>Tudo em dia por aqui.</p>
              <% } %>
            </div>
          </details>
          <a class="top-wallet-chip desktop-wallet-chip" href="/app/carteira" aria-label="Saldo da carteira">
            <span>Saldo</span>
            <strong><%= formatMoney(currentUser.walletBalance) %></strong>
            <em>Depositar</em>
          </a>
          <% if (isAdmin) { %><a class="<%= currentPath === '/admin' ? 'active' : '' %>" href="/admin">Painel</a><% } %>
          <form action="/logout" method="post">
            <button class="link-button" type="submit">Sair</button>
          </form>
        <% } else { %>
          <a class="<%= currentPath === '/login' ? 'active' : '' %>" href="/login">Entrar</a>
          <a class="button small" href="/cadastro">Cadastrar</a>
        <% } %>
      </nav>
    </header>
    <script>
      (() => {
        const button = document.querySelector(".menu-toggle");
        const menu = document.getElementById("site-menu");
        if (!button || !menu) return;

        function setOpen(open) {
          document.body.classList.toggle("menu-open", open);
          button.setAttribute("aria-expanded", open ? "true" : "false");
        }

        button.addEventListener("click", () => setOpen(!document.body.classList.contains("menu-open")));
        menu.querySelectorAll("a, button").forEach((item) => {
          item.addEventListener("click", () => setOpen(false));
        });
        window.addEventListener("resize", () => {
          if (window.innerWidth > 860) setOpen(false);
        });
      })();
    </script>
    <main>
      <% if (errors && errors.length) { %>
        <section class="flash error"><% errors.forEach((item) => { %><p><%= item %></p><% }) %></section>
      <% } %>
      <% if (successes && successes.length) { %>
        <section class="flash success"><% successes.forEach((item) => { %><p><%= item %></p><% }) %></section>
      <% } %>
